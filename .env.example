# Neon PostgreSQL connection strings
# Get these from your Neon project dashboard (https://console.neon.tech).
# Use your DEVELOPMENT branch locally; production uses the production branch.

# Pooled connection — used by the app at runtime via the Neon serverless adapter.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Unpooled (direct) connection — used by Prisma Migrate / CLI for DDL.
# Same as DATABASE_URL but without the "-pooler" segment in the host.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
